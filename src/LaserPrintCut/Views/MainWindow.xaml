<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="LaserPrintCutAddin.Views.MainWindow"
        Title="Laser Print &amp; Cut" WindowStartupLocation="CenterScreen"
        Width="800" Height="600" Loaded="MainWindow_Loaded">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <TextBlock Text="Laser Print &amp; Cut" HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="24" FontWeight="Bold" Margin="10" Grid.ColumnSpan="2"/>
        
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="10">
            <Image Source="{Binding PreviewBitmapSource}" Stretch="Uniform" Margin="5"/>
        </Border>
        
        <ScrollViewer Grid.Row="1" Grid.Column="1" Margin="10" VerticalScrollBarVisibility="Auto">
            <StackPanel Width="250">
                <TextBlock Text="Operation" FontSize="16" FontWeight="Bold" Margin="5"/>
                <RadioButton Name="rbBuildContour" Content="Build Contour" IsChecked="True" GroupName="Operation" Margin="5"/>
                <RadioButton Name="rbBuildBoxes" Content="Build Boxes" GroupName="Operation" Margin="5"/>
                
                <TextBlock Text="Contour Type" FontSize="16" FontWeight="Bold" Margin="10,5,5,5"/>
                <ComboBox Name="cbContourType" Margin="5">
                    <ComboBoxItem Content="Cutting Contour"/>
                </ComboBox>
                
                <TextBlock Text="Contour Options" FontSize="16" FontWeight="Bold" Margin="10,10,5,5"/>
                <StackPanel Margin="10">
                    <TextBlock Text="Corner" Margin="0,0,0,5"/>
                    <ComboBox Name="cbCorner" Margin="0,0,0,10">
                        <ComboBoxItem Content="Round (volta/arched)"/>
                        <ComboBoxItem Content="Sharp (Live)" IsSelected="True"/>
                        <ComboBoxItem Content="Bevel (Chamfered)"/>
                    </ComboBox>
                    
                    <TextBlock Text="Outline/Offset (mm)" Margin="0,10,0,5"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Name="tbOffsetValue" Text="0.5" Width="60" Margin="0,0,10,0"/>
                        <TextBlock Text="mm" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Threshold/Limiar de Contraste (0-255)" Margin="0,10,0,5"/>
                    <Slider Name="sliderThreshold" Minimum="0" Maximum="255" Value="128" 
                            Margin="0,0,0,10" TickFrequency="51" IsSnapToTickEnabled="True" ValueChanged="ThresholdSlider_ValueChanged"/>
                    <TextBox Name="tbThresholdValue" Text="128" Width="60" Margin="0,0,0,10" HorizontalAlignment="Right"/>
                </StackPanel>
                
                <StackPanel Margin="10,5">
                    <CheckBox Name="cbKeepHoles" Content="Maintain holes" VerticalAlignment="Center" Margin="5,0,0,0"/>
                </StackPanel>
                
                <TextBlock Text="Output Mode" FontSize="16" FontWeight="Bold" Margin="10,10,5,5"/>
                <StackPanel Margin="10">
                    <RadioButton Name="rbOnlyContour" Content="Only Contour (Generates only the vector overlay to the image for general use)" IsChecked="True" GroupName="OutputMode" Margin="5"/>
                    <RadioButton Name="rbSeparatePrintCut" Content="Separate Cut/Print for LightBurn (Executes the Print &amp; Cut flow)" GroupName="OutputMode" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Name="btnAccept" Content="Accept" Width="100" Height="30" Margin="5" Click="BtnAccept_Click"/>
            <Button Name="btnCancel" Content="Cancel" Width="100" Height="30" Margin="5" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
